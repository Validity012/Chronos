# ─── Telegram ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Groq AI (FREE - https://console.groq.com) ───
# Get your free API key - no credit card required
GROQ_API_KEY=your_groq_api_key_here

# ─── Database ───
DB_PATH=./data/finance.db

# ─── App ───
PORT=3000
LOG_LEVEL=info

# ─── Model ───
# Free Groq models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Budget Period ───
BUDGET_PERIOD=monthly  # monthly, weekly
